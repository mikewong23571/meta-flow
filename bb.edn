{:tasks
 {;; -- runtime ops ---------------------------------------------------------
  init
  {:doc "Initialize SQLite and runtime directories"
   :requires ([babashka.tasks :refer [shell]])
   :task (shell "clojure -M -m meta-flow.main init")}

  defs:validate
  {:doc "Validate workflow definitions"
   :requires ([babashka.tasks :refer [shell]])
   :task (shell "clojure -M -m meta-flow.main defs validate")}

  ;; -- dev toolchain -------------------------------------------------------
  repl
  {:doc "Start nREPL server on port 7888"
   :override-builtin true
   :requires ([babashka.tasks :refer [shell]])
   :task (shell "clojure -M:nrepl")}

  test
  {:doc "Run test suite once (kaocha); extra args forwarded, e.g. bb test --focus my.ns"
   :requires ([babashka.tasks :refer [shell]])
   :task (apply shell "clojure -M:kaocha" *command-line-args*)}

  test:watch
  {:doc "Run tests in watch mode -- reruns on file change"
   :requires ([babashka.tasks :refer [shell]])
   :task (shell "clojure -M:kaocha --watch")}

  lint
  {:doc "Static analysis via clj-kondo plus src file-length and directory-width governance"
   :requires ([babashka.tasks :refer [shell]])
   :task (do
           (shell "clojure -M:lint")
           (shell "clojure -M -m meta-flow.lint.file-length"))}

  coverage
  {:doc "Run test coverage governance via Kaocha + Cloverage"
   :requires ([babashka.tasks :refer [shell]])
   :task (shell "clojure -M -m meta-flow.lint.coverage")}

  fmt
  {:doc "Reformat source files in place (cljfmt fix)"
  :requires ([babashka.tasks :refer [shell]])
  :task (shell "clojure -M:fmt")}

  fmt:check
  {:doc "Check formatting without modifying files (cljfmt check)"
   :requires ([babashka.tasks :refer [shell]])
   :task (shell "clojure -M:fmt/check")}

  ;; -- CI entry point ------------------------------------------------------
  check
  {:doc "Run all checks: fmt:check -> lint -> test -> coverage"
   :requires ([babashka.tasks :refer [run]])
   :task (do (run 'fmt:check)
             (run 'lint)
             (run 'test)
             (run 'coverage))}}}
