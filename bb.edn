{:tasks
 {;; -- runtime ops ---------------------------------------------------------
  init
  {:doc "Initialize SQLite and runtime directories"
   :requires ([babashka.tasks :refer [shell]])
   :task (shell "clojure -M:native-access -m meta-flow.main init")}

  runtime:init-codex-home
  {:doc "Install CODEX_HOME templates and skills for all Codex runtime profiles"
   :requires ([babashka.tasks :refer [shell]])
   :task (shell "clojure -M:native-access -m meta-flow.main runtime init-codex-home")}

  enqueue-repo-arch
  {:doc "Enqueue a repo architecture task: bb enqueue-repo-arch --repo <url> --notify-email <email>"
   :requires ([babashka.tasks :refer [shell]])
   :task (apply shell "clojure -M:native-access -m meta-flow.main enqueue-repo-arch" *command-line-args*)}

  scheduler:run
  {:doc "Run scheduler loop until task completes: META_FLOW_ENABLE_CODEX_SMOKE=1 bb scheduler:run --task-id <id>"
   :requires ([babashka.tasks :refer [shell]])
   :task (apply shell "clojure -M:native-access -m meta-flow.main scheduler run" *command-line-args*)}

  defs:validate
  {:doc "Validate workflow definitions"
   :requires ([babashka.tasks :refer [shell]])
   :task (shell "clojure -M:native-access -m meta-flow.main defs validate")}

  ;; -- dev toolchain -------------------------------------------------------
  repl
  {:doc "Start nREPL server on port 7888"
   :override-builtin true
   :requires ([babashka.tasks :refer [shell]])
   :task (shell "clojure -M:native-access:nrepl")}

  test
  {:doc "Run test suite once (kaocha); extra args forwarded, e.g. bb test --focus my.ns"
   :requires ([babashka.tasks :refer [shell]])
   :task (apply shell "clojure -M:native-access:kaocha" *command-line-args*)}

  test:watch
  {:doc "Run tests in watch mode -- reruns on file change"
   :requires ([babashka.tasks :refer [shell]])
   :task (shell "clojure -M:native-access:kaocha --watch")}

  lint
  {:doc "Static analysis via clj-kondo plus src file-length and directory-width governance"
   :requires ([babashka.tasks :refer [shell]])
   :task (do
           (shell "clojure -M:lint")
           (shell "clojure -M -m meta-flow.lint.file-length"))}

  check:pre-commit
  {:doc "Run the fast local commit gate: fmt:check -> lint"
   :requires ([babashka.tasks :refer [run]])
   :task (do (run 'fmt:check)
             (run 'lint))}

  coverage
  {:doc "Run test coverage governance via Kaocha + Cloverage"
   :requires ([babashka.tasks :refer [shell]])
   :task (shell "clojure -M:native-access:governance -m meta-flow.lint.coverage")}

  fmt
  {:doc "Reformat source files in place (cljfmt fix)"
   :requires ([babashka.tasks :refer [shell]])
   :task (shell "clojure -M:fmt")}

  fmt:check
  {:doc "Check formatting without modifying files (cljfmt check)"
   :requires ([babashka.tasks :refer [shell]])
   :task (shell "clojure -M:fmt/check")}

  ;; -- CI entry point ------------------------------------------------------
  check
  {:doc "Run the default AI-first governance gate with concise, high-signal output"
   :requires ([babashka.tasks :refer [shell]])
   :task (shell "clojure -M:native-access:governance -m meta-flow.lint.check")}

  check:verbose
  {:doc "Run the verbose human-debugging gate: fmt:check -> lint -> test -> coverage"
   :requires ([babashka.tasks :refer [run]])
   :task (do (run 'fmt:check)
             (run 'lint)
             (run 'test)
             (run 'coverage))}}}
